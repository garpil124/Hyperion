def save_partner(data):
    try:
        print("\nрҹ”Ҙ SAVE PARTNER DIPANGGIL")
        print("рҹ“Ҡ TOTAL DATA MASUK:", len(data))

        print("рҹ“Қ CALL TRACE (SAFE MODE)")

        # ================= VALIDASI =================
        if not isinstance(data, list):
            print("вқҢ  DATA BUKAN LIST, CANCEL")
            return

        clean_data = []
        seen = set()

        for p in data:
            if isinstance(p, dict) and "link" in p:
                link = p.get("link")

                if not link or not isinstance(link, str):
                    continue

                if link in seen:
                    continue

                seen.add(link)
                clean_data.append(p)

        # ================= рҹ”’ ANTI WIPE =================
        if len(clean_data) == 0 and os.path.exists(PARTNER_FILE):
            print("рҹҡЁ DETECT DATA JADI 0 вҶ’ SAVE DIBATALKAN (ANTI HILANG)")
            return

        # ================= BACKUP =================
        if os.path.exists(PARTNER_FILE):
            backup_dir = "backup_partner"

            if not os.path.exists(backup_dir):
                os.makedirs(backup_dir)

            timestamp = int(time.time())
            backup_file = f"{backup_dir}/partner_{timestamp}.json"

            try:
                shutil.copy(PARTNER_FILE, backup_file)
                print(f"рҹ“Ұ Backup dibuat: {backup_file}")
            except Exception as e:
                print("вқҢ  Backup error:", e)

        # ================= SAFE WRITE =================
        temp_file = PARTNER_FILE + ".tmp"

        with open(temp_file, "w") as f:
            json.dump(clean_data, f, indent=2)

        os.replace(temp_file, PARTNER_FILE)

        print(f"вң…  BERHASIL SAVE ({len(clean_data)} data)")

        # ================= AUTO CLEAN BACKUP =================
        try:
            if os.path.exists("backup_partner"):
                backups = sorted(os.listdir("backup_partner"))

                if len(backups) > 20:
                    for old in backups[:-20]:
                        os.remove(f"backup_partner/{old}")
                        print(f"рҹ—‘пёҸ Backup lama dihapus: {old}")

        except Exception:
            pass

    except Exception as e:
        print("вқҢ  SAVE PARTNER ERROR:", e)
        traceback.print_exc()

