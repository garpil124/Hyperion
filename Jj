# ================= BUILD BUTTON =================
def build_buttons(page, total):
    buttons = []

    if page > 0:
        buttons.append(InlineKeyboardButton("в¬…пёҸ Prev", callback_data=f"partner_{page-1}"))

    if (page + 1) * PAGE_SIZE < total:
        buttons.append(InlineKeyboardButton("вһЎпёҸ Next", callback_data=f"partner_{page+1}"))

    buttons.append(InlineKeyboardButton("вқҢ Close", callback_data="partner_close"))

    return InlineKeyboardMarkup([buttons])


